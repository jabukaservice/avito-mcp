# Avito API credentials
# Get them at: https://developers.avito.ru/ → Create App → OAuth2 credentials
# Required scopes: messenger:read, messenger:write, item:info

# ── Account 1 (primary) ──────────────────────────────────────────────
AVITO_CLIENT_ID=your_client_id_here
AVITO_CLIENT_SECRET=your_client_secret_here
AVITO_USER_ID=your_user_id_here
AVITO_ACCOUNT_NAME=main

# ── Account 2 (optional) ─────────────────────────────────────────────
# Set user_id to "auto" to auto-detect on startup
# AVITO_CLIENT_ID_2=your_second_client_id
# AVITO_CLIENT_SECRET_2=your_second_client_secret
# AVITO_USER_ID_2=auto
# AVITO_ACCOUNT_NAME_2=second

# ── SSL (optional) ───────────────────────────────────────────────────
# Set to "false" if your Mac has proxy/antivirus intercepting TLS certs
# AVITO_SSL_VERIFY=false
